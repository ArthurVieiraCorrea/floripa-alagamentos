# Google OAuth — crie um projeto em https://console.cloud.google.com
GOOGLE_CLIENT_ID=seu_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Segredos da sessão — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=uma_string_aleatoria_qualquer
ENCRYPTION_KEY=64_caracteres_hex_gerados_com_o_comando_acima

# Visual Crossing — crie conta gratuita em https://www.visualcrossing.com
VISUAL_CROSSING_API_KEY=sua_chave_aqui
