# Google OAuth2 — from Google Cloud Console → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Express Session — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# AES-256 key for refresh token encryption (32 bytes = 64 hex chars)
# generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Existing
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
